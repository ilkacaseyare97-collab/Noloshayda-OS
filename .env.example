# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub!

PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string (from mongodb.com/cloud/atlas)
# Example format only – replace with YOUR cluster URI:
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/noloshayda?retryWrites=true&w=majority

# JWT secret – use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=30d
